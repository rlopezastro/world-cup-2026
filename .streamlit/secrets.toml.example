# Streamlit secrets template. Copy to `.streamlit/secrets.toml` for local use, or
# paste the contents into the app's Secrets box on Streamlit Community Cloud.
# The real secrets.toml is gitignored — never commit your keys.

# Read-only public deployment: hides all key inputs and fetch controls, serves the
# committed JSON only. Set this to true on the published app.
published = true

# football-data.org token — needed by the PUBLISHED app ONLY for in-app live SCORES
# (polled every ~2 min, shared across all viewers via a TTL cache, and only while a
# game is in play). It is read server-side via st.secrets and never sent to browsers.
# football_data = "your-football-data-org-token"

# The Odds API key is NOT needed in the app. Betting odds are refreshed out-of-band by
# the scheduled GitHub Action (refresh_data.py), using ODDS_API_KEY from the repo's
# Actions secrets — keep it there, not here.
# odds_api = "your-the-odds-api-key"

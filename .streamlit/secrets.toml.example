# Streamlit secrets template. Copy to `.streamlit/secrets.toml` for local use, or
# paste the contents into the app's Secrets box on Streamlit Community Cloud.
# The real secrets.toml is gitignored — never commit your keys.

# Read-only public deployment: hides all key inputs and fetch controls, serves the
# committed JSON only. Set this to true on the published app.
published = true

# Keys are NOT needed by the published (read-only) app. You only need these if you
# want in-app fetching somewhere. For the public site, leave them out and let the
# scheduled GitHub Action (with its own repo secrets) refresh the data instead.
# football_data = "your-football-data-org-token"
# odds_api = "your-the-odds-api-key"
